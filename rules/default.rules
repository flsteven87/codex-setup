# Codex command safety rules (Starlark).
# Docs: https://developers.openai.com/codex/rules

# Pushing code is allowed after the user has asked the agent to publish changes.
prefix_rule(
    pattern=["git", "push"],
    decision="allow",
    justification="The local workflow delegates verified repository publishing to Codex.",
    match=["git push origin feature/my-branch"],
)

# Local commits are allowed.
prefix_rule(
    pattern=["git", "commit"],
    decision="allow",
    justification="Local commits record staged changes without modifying remote state.",
    match=["git commit -m \"...\""],
)

prefix_rule(
    pattern=["git", "rebase"],
    decision="allow",
    justification="The local workflow permits Codex to rebase when it is needed for repository maintenance.",
    match=["git rebase main"],
)

prefix_rule(
    pattern=["git", "reset", "--hard"],
    decision="prompt",
    justification="Hard reset can discard local changes.",
    match=["git reset --hard HEAD~1"],
)

prefix_rule(
    pattern=["git", "clean", "-fdx"],
    decision="prompt",
    justification="git clean -fdx permanently removes untracked files.",
    match=["git clean -fdx"],
)

# Recursive or root-protection-bypassing deletes require confirmation.
prefix_rule(
    pattern=["rm", ["-rf", "-fr", "-r", "-R", "-Rf", "-fR", "--recursive"]],
    decision="prompt",
    justification="Recursive delete can remove an entire directory tree.",
    match=[
        "rm -rf build/",
        "rm -fr build/",
        "rm -r build/",
        "rm -R build/",
        "rm --recursive build/",
    ],
    not_match=["rm file.txt"],
)

prefix_rule(
    pattern=["rm", ["-f", "--force"], ["-r", "-R", "--recursive"]],
    decision="prompt",
    justification="Recursive forced delete can remove an entire directory tree.",
    match=[
        "rm -f -r build/",
        "rm --force --recursive build/",
    ],
)

prefix_rule(
    pattern=["rm", "--no-preserve-root"],
    decision="prompt",
    justification="Disabling root preservation can cause catastrophic deletion.",
    match=["rm --no-preserve-root -rf /"],
)

prefix_rule(
    pattern=["sudo"],
    decision="prompt",
    justification="sudo runs commands with elevated privileges; confirm intent.",
    match=["sudo rm -rf /some/path"],
)

prefix_rule(
    pattern=["chmod", "777"],
    decision="prompt",
    justification="chmod 777 is almost always unsafe; confirm intent and consider least privilege.",
    match=["chmod 777 some-file"],
)

prefix_rule(
    pattern=["kill", "-9"],
    decision="prompt",
    justification="SIGKILL (-9) force-kills processes; confirm intent.",
    match=["kill -9 12345"],
)

prefix_rule(
    pattern=["killall"],
    decision="prompt",
    justification="killall can terminate multiple processes; confirm intent.",
    match=["killall node"],
)

prefix_rule(
    pattern=["pkill"],
    decision="prompt",
    justification="pkill can terminate multiple processes; confirm intent.",
    match=["pkill -f uvicorn"],
)

prefix_rule(
    pattern=["shutdown"],
    decision="prompt",
    justification="shutdown affects system availability; confirm intent.",
    match=["shutdown -h now"],
)

prefix_rule(
    pattern=["reboot"],
    decision="prompt",
    justification="reboot affects system availability; confirm intent.",
    match=["reboot"],
)

prefix_rule(
    pattern=["launchctl"],
    decision="prompt",
    justification="launchctl changes system services; confirm intent.",
    match=["launchctl kickstart -k system/com.example.service"],
)

prefix_rule(
    pattern=["defaults", "write"],
    decision="prompt",
    justification="defaults write changes system/app preferences; confirm intent.",
    match=["defaults write com.example Foo -bool true"],
)

prefix_rule(
    pattern=["networksetup"],
    decision="prompt",
    justification="networksetup changes system network settings; confirm intent.",
    match=["networksetup -setairportpower en0 off"],
)

prefix_rule(
    pattern=["csrutil"],
    decision="prompt",
    justification="csrutil changes system integrity protection settings; confirm intent.",
    match=["csrutil status"],
)

prefix_rule(
    pattern=["spctl"],
    decision="prompt",
    justification="spctl changes Gatekeeper policy; confirm intent.",
    match=["spctl --status"],
)

# Prefer uv in uv-based Python projects (avoid bare pip installs).
prefix_rule(
    pattern=["pip", "install"],
    decision="prompt",
    justification="Prefer `uv add ...` in projects managed by uv. Use pip only when truly necessary.",
    match=["pip install ruff"],
)

prefix_rule(
    pattern=["pip3", "install"],
    decision="prompt",
    justification="Prefer `uv add ...` in projects managed by uv. Use pip only when truly necessary.",
    match=["pip3 install ruff"],
)

prefix_rule(
    pattern=["python", "-m", "pip"],
    decision="prompt",
    justification="Prefer `uv add ...` in projects managed by uv. Use pip only when truly necessary.",
    match=["python -m pip install ruff"],
)

prefix_rule(
    pattern=["python3", "-m", "pip"],
    decision="prompt",
    justification="Prefer `uv add ...` in projects managed by uv. Use pip only when truly necessary.",
    match=["python3 -m pip install ruff"],
)

# High-risk disk operations should not be run.
prefix_rule(
    pattern=["mkfs"],
    decision="forbidden",
    justification="Disk formatting is destructive and out of scope for normal development tasks.",
    match=["mkfs /dev/sda1"],
)

prefix_rule(
    pattern=["dd"],
    decision="prompt",
    justification="dd can overwrite disks or large files if used incorrectly.",
    match=["dd if=input.img of=/dev/sda"],
)
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["uv", "run", "pytest"], decision="allow")
prefix_rule(pattern=["uv", "run", "python"], decision="allow")
prefix_rule(pattern=["docker-compose", "up", "-d"], decision="allow")
prefix_rule(pattern=["docker", "compose", "up", "-d"], decision="allow")
prefix_rule(pattern=["uv", "run", "black"], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff"], decision="allow")
prefix_rule(pattern=["git", "rm", "--cached"], decision="allow")
prefix_rule(pattern=["git", "mv"], decision="allow")
prefix_rule(pattern=["git", "stash", "drop"], decision="allow")
prefix_rule(pattern=["git", "add", "-u"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["codex", "--version"], decision="allow")
